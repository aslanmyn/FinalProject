# App
APP_PROFILE=postgres
APP_WEB_FRONTEND_URL=http://localhost:5173
APP_HOST_PORT=8080
FRONTEND_HOST_PORT=3000
APP_SEED_ENABLED=false
APP_SEED_CONFIRM_TOKEN=
APP_STORAGE_ROOT=./storage
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_BASE_URL=

# PostgreSQL
POSTGRES_DB=final_project
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<strong_db_password>
DB_URL=jdbc:postgresql://postgres:5432/final_project
DB_USER=postgres
DB_PASSWORD=<strong_db_password>

# Security
JWT_SECRET=<very_long_random_secret>
APP_STORAGE_SIGNING_SECRET=<very_long_random_secret>

# AI Assistant
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_READ_ONLY=true
GEMINI_API_KEY=<gemini_api_key>
GEMINI_MODEL=gemini-2.5-flash

# Optional
JWT_EXPIRATION_MINUTES=720
JWT_REFRESH_EXPIRATION_DAYS=30
APP_STORAGE_MAX_FILE_MB=20
APP_STORAGE_LINK_TTL_MINUTES=30
APP_MULTIPART_MAX_FILE_SIZE=25MB
APP_MULTIPART_MAX_REQUEST_SIZE=25MB
